{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true",
        "isAdmin": {
          ".write": "auth.uid !== $uid && root.child('users').child(auth.uid).child('isAdmin').val() === true || $uid === auth.uid && newData.val() === false"
        },
        "verified": {
          ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true"
        },
        "isBanned": {
          ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true"
        },
        "displayName": {
          ".write": "$uid === auth.uid",
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30"
        },
        "username": {
          ".write": "$uid === auth.uid",
          ".validate": "newData.isString() && newData.val().matches(/^[a-zA-Z0-9_]{3,20}$/)"
        },
        "bio": {
          ".write": "$uid === auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 160"
        },
        "avatarData": {
          ".write": "$uid === auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 280000"
        },
        "status": {
          ".write": "$uid === auth.uid"
        },
        "lastSeen": {
          ".write": "$uid === auth.uid"
        },
        "hideLastSeen": {
          ".write": "$uid === auth.uid"
        },
        "dmPrivacy": {
          ".write": "$uid === auth.uid"
        },
        "wallpaper": {
          ".write": "$uid === auth.uid"
        },
        "blockedUsers": {
          ".write": "$uid === auth.uid"
        },
        "isNewUser": {
          ".write": "$uid === auth.uid"
        }
      }
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null && !data.exists()"
      }
    },
    "rooms": {
      ".read": "auth != null",
      "$roomId": {
        ".write": "auth != null && (!data.exists() || data.child('createdBy').val() === root.child('users').child(auth.uid).child('username').val() || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
        "msgs": {
          "$msgId": {
            ".write": "auth != null && (!data.exists() && !root.child('banned').child(root.child('users').child(auth.uid).child('username').val()).exists() || data.child('uid').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
            ".validate": "!newData.exists() || newData.hasChildren(['text','uid','ts','type'])",
            "text": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 2000"
            },
            "uid": {
              ".validate": "newData.val() === auth.uid && (!data.exists() || data.val() === auth.uid)"
            },
            "ts": {
              ".validate": "newData.isNumber()"
            }
          }
        },
        "members": {
          "$uid": {
            ".write": "$uid === auth.uid"
          }
        },
        "subscribers": {
          "$uid": {
            ".write": "$uid === auth.uid"
          }
        },
        "views": {
          "$uid": {
            ".write": "$uid === auth.uid"
          }
        },
        "admins": {
          "$uid": {
            ".write": "auth != null && (root.child('rooms').child($roomId).child('createdBy').val() === root.child('users').child(auth.uid).child('username').val() || root.child('users').child(auth.uid).child('isAdmin').val() === true)"
          }
        },
        "pinned": {
          ".write": "root.child('rooms').child($roomId).child('admins').hasChild(auth.uid) || root.child('users').child(auth.uid).child('isAdmin').val() === true || root.child('rooms').child($roomId).child('createdBy').val() === root.child('users').child(auth.uid).child('username').val()"
        }
      }
    },
    "dms": {
      ".read": "auth != null",
      "$dmId": {
        ".read": "auth != null && (data.child('p').child(auth.uid).val() === true || !data.exists())",
        ".write": "auth != null && (!data.exists() || data.child('p').child(auth.uid).val() === true)",
        "msgs": {
          "$msgId": {
            ".write": "auth != null && root.child('dms').child($dmId).child('p').child(auth.uid).val() === true && (!data.exists() || data.child('uid').val() === auth.uid)",
            ".validate": "!newData.exists() || newData.hasChildren(['text','uid','ts'])",
            "text": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 2000"
            },
            "uid": {
              ".validate": "newData.val() === auth.uid && (!data.exists() || data.val() === auth.uid)"
            },
            "ts": {
              ".validate": "newData.isNumber()"
            },
            "deletedFor": {
              "$uid": {
                ".write": "$uid === auth.uid"
              }
            }
          }
        },
        "unread": {
          "$uid": {
            ".write": "auth != null && root.child('dms').child($dmId).child('p').child(auth.uid).val() === true"
          }
        },
        "lastMsg": {
          ".write": "auth != null && root.child('dms').child($dmId).child('p').child(auth.uid).val() === true"
        },
        "deleted": {
          "$uid": {
            ".write": "$uid === auth.uid"
          }
        }
      }
    },
    "banned": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      "$username": {
        ".read": "auth != null"
      }
    },
    "typing": {
      "$roomId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && $uid === auth.uid",
          ".validate": "newData.isString()"
        }
      }
    },
    "dmTyping": {
      "$dmId": {
        ".read": "auth != null && root.child('dms').child($dmId).child('p').child(auth.uid).val() === true",
        "$uid": {
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },
    "logs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true"
    },
    "reports": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".indexOn": [
        "ts"
      ],
      "$reportId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['type','reason','by','ts'])"
      }
    },
    "settings": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      "maintenance": {
        ".read": true
      },
      "announcement": {
        ".read": true
      }
    }
  }
}